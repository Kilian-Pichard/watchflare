# PostgreSQL Configuration
POSTGRES_USER=watchflare
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=watchflare

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=change_me_to_random_string_in_production

# Ports (exposed on host)
PORT=8080
GRPC_PORT=50051

# TLS Mode: auto (self-signed) or custom (bring your own certs)
TLS_MODE=auto

# Cookie domain (set to your domain when using HTTPS reverse proxy)
# COOKIE_DOMAIN=watchflare.example.com

# Secure flag on the JWT cookie (default: true when ENV=production).
# Set to false ONLY if serving over plain HTTP without a TLS reverse proxy.
# WARNING: disabling this allows session cookies to travel in cleartext —
# anyone on the network can intercept them. Use HTTPS in production instead.
# COOKIE_SECURE=false

# gRPC HMAC timestamp window in seconds
GRPC_TIMESTAMP_WINDOW=300
