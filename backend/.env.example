# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=watchflare
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=watchflare
POSTGRES_SSLMODE=disable

# Server Configuration
# HTTP port is fixed at 8080. Use a reverse proxy (nginx, Caddy) to expose a different public port.
GRPC_PORT=50051

# TLS Configuration
TLS_MODE=auto                             # auto (self-signed) or custom (bring your own certs)
TLS_PKI_DIR=./data/pki                    # Dev: ./data/pki | Production: /var/lib/watchflare/pki

# Custom TLS (only used if TLS_MODE=custom)
# TLS_CERT_FILE=/path/to/custom/cert.pem
# TLS_KEY_FILE=/path/to/custom/key.pem
# TLS_CA_FILE=/path/to/custom/ca.pem

# gRPC Security (HMAC is mandatory for all authenticated requests)
GRPC_TIMESTAMP_WINDOW=300

# JWT Configuration (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
COOKIE_SECURE=false             # Set to true in production when serving over HTTPS
# COOKIE_DOMAIN=watchflare.io  # Set in production for secure cookies

# Environment
ENV=development
