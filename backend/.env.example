# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=watchflare
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=watchflare
POSTGRES_SSLMODE=disable

# Backend Configuration
# HTTP port is fixed at 8080. Use a reverse proxy (nginx, Caddy) to expose a different public port.
GRPC_PORT=50051

# TLS Configuration
TLS_MODE=auto                             # auto (self-signed) or custom (bring your own certs)
TLS_PKI_DIR=./data/pki                    # Dev: ./data/pki | Production: /var/lib/watchflare/pki

# Custom TLS (only used if TLS_MODE=custom)
# TLS_CERT_FILE=/path/to/custom/cert.pem
# TLS_KEY_FILE=/path/to/custom/key.pem
# TLS_CA_FILE=/path/to/custom/ca.pem

# gRPC Security (HMAC is mandatory for all authenticated requests)
GRPC_TIMESTAMP_WINDOW=300

# JWT Configuration (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# SMTP password encryption key (generate with: openssl rand -base64 32)
# Required to save an SMTP password — the backend will warn on startup if unset
SMTP_ENCRYPTION_KEY=your-smtp-encryption-key-change-this-in-production

# Security
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# COOKIE_DOMAIN=watchflare.io   # Set in production for secure cookies

# Cookie security is auto-detected per request (recommended — no config needed):
#   - Direct HTTPS (TLS_CERT_FILE/TLS_KEY_FILE set)  → Secure flag on
#   - Behind reverse proxy sending X-Forwarded-Proto  → Secure flag on
#   - Plain HTTP                                       → Secure flag off
# Use COOKIE_SECURE only to force-override auto-detection:
# COOKIE_SECURE=true             # Force Secure flag on (requires HTTPS or browsers will reject cookies)
# COOKIE_SECURE=false            # Force Secure flag off (not recommended in production)

# Trusted proxy IPs allowed to set X-Forwarded-Proto (default: loopback only).
# Add your reverse proxy IP if it runs on a separate host.
# TRUSTED_PROXIES=127.0.0.1,::1

# Environment
ENV=development
