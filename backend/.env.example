# Server Configuration
PORT=8080
GRPC_PORT=50051

# gRPC Security
GRPC_ENABLE_TLS=false
GRPC_CERT_FILE=/etc/watchflare/certs/server-cert.pem
GRPC_KEY_FILE=/etc/watchflare/certs/server-key.pem
GRPC_REQUIRE_HMAC=false
GRPC_TIMESTAMP_WINDOW=300

# Database
DB_PATH=./watchflare.db

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Security
# Format: CORS_ORIGINS=http://localhost:5173,http://localhost:4173
CORS_ORIGINS=http://localhost:5173

# Environment
ENV=development
